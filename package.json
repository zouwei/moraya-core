{
  "name": "@moraya/core",
  "version": "0.10.1",
  "description": "Shared markdown editor core for Moraya desktop and Moraya Web. ProseMirror schema, markdown-it parser, prosemirror-markdown serializer, plugins, and editor lifecycle factories. Pure ESM, host-agnostic, dependency-injected.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./markdown": {
      "import": "./dist/markdown.js",
      "types": "./dist/markdown.d.ts"
    },
    "./commands": {
      "import": "./dist/commands.js",
      "types": "./dist/commands.d.ts"
    },
    "./doc-cache": {
      "import": "./dist/doc-cache.js",
      "types": "./dist/doc-cache.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./style": "./dist/style.css",
    "./plugins/*": {
      "import": "./dist/plugins/*.js",
      "types": "./dist/plugins/*.d.ts"
    },
    "./plugins/*.css": "./dist/plugins/*.css",
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./i18n/locales/*.json": "./dist/i18n/locales/*.json",
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    },
    "./ai/types": {
      "import": "./dist/ai/types.js",
      "types": "./dist/ai/types.d.ts"
    },
    "./ai/image": {
      "import": "./dist/ai/image.js",
      "types": "./dist/ai/image.d.ts"
    },
    "./ai/voice": {
      "import": "./dist/ai/voice.js",
      "types": "./dist/ai/voice.d.ts"
    },
    "./ai/drivers/*": {
      "import": "./dist/ai/drivers/*.js",
      "types": "./dist/ai/drivers/*.d.ts"
    },
    "./chat-markdown": {
      "import": "./dist/chat-markdown/index.js",
      "types": "./dist/chat-markdown/index.d.ts"
    },
    "./memory": {
      "import": "./dist/memory/index.js",
      "types": "./dist/memory/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zouwei/moraya-core.git"
  },
  "license": "GPL-3.0-only",
  "sideEffects": [
    "./dist/style.css",
    "./dist/plugins/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "spdx:check": "node scripts/check-spdx.mjs",
    "spdx:fix": "node scripts/check-spdx.mjs --fix",
    "version:bump": "node scripts/bump-version.mjs",
    "prepublishOnly": "npm run spdx:check && npm run build && npm run test",
    "release": "node scripts/release-with-consumers.mjs"
  },
  "peerDependencies": {
    "diff": "^9.0.0",
    "highlight.js": "^11.11.0",
    "katex": "^0.16.28",
    "markdown-it": "^14.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.0.0",
    "node-emoji": "^2.0.0",
    "prosemirror-commands": "^1.7.0",
    "prosemirror-dropcursor": "^1.8.0",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.0",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-markdown": "^1.13.0",
    "prosemirror-model": "^1.20.0",
    "prosemirror-schema-list": "^1.5.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-tables": "^1.8.0",
    "prosemirror-view": "^1.33.0",
    "node-diff3": "^3.2.1"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    },
    "diff": {
      "optional": true
    },
    "node-diff3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "diff": "^9.0.0",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.28",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-texmath": "^1.0.0",
    "node-diff3": "^3.2.1",
    "node-emoji": "^2.2.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.6",
    "tsup": "^8.3.0",
    "typescript": "~5.6.2",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
