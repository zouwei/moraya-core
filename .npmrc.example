# GitHub Packages auth template for `@moraya/markdown-core`.
# Copy to ~/.npmrc (preferred — keeps token out of the repo) or to ./.npmrc
# (gitignored locally; never commit a populated copy).
#
# Required scope on the GitHub PAT:
#   - read:packages   (consumers — installing this package)
#   - write:packages  (maintainers — running `pnpm publish` to GitHub Packages)
#
# CI (GitHub Actions): use ${{ secrets.GITHUB_TOKEN }} via setup-node's
# `registry-url` + `scope` inputs (see .github/workflows/publish.yml).

@moraya:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
